class Handler(BaseHTTPRequestHandler):
    app = None

    def _read_json(self):
        length = int(self.headers.get("Content-Length", "0"))
        payload = self.rfile.read(length) if length else b"{}"
        return json.loads(payload.decode("utf-8"))

    def _send(self, status_code, payload, content_type="application/json; charset=utf-8", extra_headers=None):
        body = payload.encode("utf-8") if isinstance(payload, str) else json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status_code)
        self.send_header("Content-Type", content_type)
        if extra_headers:
            for key, value in extra_headers.items():
                self.send_header(key, value)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _require_auth(self):
        if self.app.verify_authorization_header(self.headers.get("Authorization", "")):
            return True
        self._send(
            401,
            {"error": "unauthorized"},
            extra_headers={"WWW-Authenticate": f'Basic realm="{self.app.auth_realm()}"'},
        )
        return False

    def do_GET(self):
        try:
            parsed = urlparse(self.path)
            if parsed.path == "/healthz":
                self._send(200, {"ok": True})
                return
            if not self._require_auth():
                return
            if parsed.path == "/":
                status = self.app.build_status()
                self._send(200, html_page(status), "text/html; charset=utf-8")
                return
            if parsed.path == "/api/status":
                self._send(200, self.app.build_status())
                return
            self._send(404, {"error": "not found"})
        except Exception as error:
            self._send(500, {"error": str(error)})

    def do_POST(self):
        try:
            parsed = urlparse(self.path)
            if not self._require_auth():
                return
            if parsed.path == "/api/rotation/run":
                self._send(200, {"state": rotate_now(self.app.config, force_new=True)})
                return
            if parsed.path == "/api/rotation/settings":
                payload = self._read_json()
                config = self.app.config
                config["rotation"]["enabled"] = bool(payload.get("enabled"))
                schedule = (payload.get("on_calendar") or "").strip()
                if not schedule:
                    raise ValueError("Нужно передать OnCalendar")
                config["rotation"]["window_size"] = payload.get("window_size", config["rotation"].get("window_size", 1))
                config["rotation"]["window_size"] = normalize_window_size(config)
                config["rotation"]["on_calendar"] = schedule
                validate_rotation_slots(config)
                reconcile_sni_list(config, read_sni_entries(config["sni_list_path"]))
                write_json(self.app.config_path, config)
                set_timer_state(config, config["rotation"]["enabled"])
                append_log(config["runtime_log_path"], f"rotation settings updated: enabled={config['rotation']['enabled']} on_calendar={schedule} window_size={config['rotation']['window_size']}")
                self._send(200, {"ok": True})
                return
            if parsed.path == "/api/sni-list":
                payload = self._read_json()
                text = payload.get("text", "")
                entries = parse_sni_entries_text(text)
                Path(self.app.config["sni_list_path"]).write_text(text.strip() + "\n", encoding="utf-8")
                state = reconcile_sni_list(self.app.config, entries)
                append_log(self.app.config["runtime_log_path"], "sni list updated")
                self._send(200, {"ok": True, "state": state})
                return
            if parsed.path == "/api/fail2ban/settings":
                payload = self._read_json()
                for jail, settings in payload.items():
                    if not isinstance(settings, dict):
                        raise ValueError(f"Некорректные настройки jail: {jail}")
                    int(settings.get("maxretry", "0"))
                write_fail2ban_override(self.app.config, payload)
                self._send(200, {"ok": True})
                return
            self._send(404, {"error": "not found"})
        except Exception as error:
            self._send(500, {"error": str(error)})

    def log_message(self, fmt, *args):
        append_log(self.app.config["runtime_log_path"], fmt % args)


def serve(config_path):
    app = App(config_path)
    config = app.config
    try:
        entries = read_sni_entries(config["sni_list_path"])
        with ROTATION_LOCK:
            connection = sqlite3.connect(config["xui_db_path"])
            connection.row_factory = sqlite3.Row
            try:
                deleted = prune_extra_slot_inbounds(connection, config)
                if deleted:
                    run_command(["systemctl", "restart", config["xui_service_unit"]])
                    append_log(config["runtime_log_path"], f"startup prune: deleted slot inbounds on ports {deleted}")
            finally:
                connection.close()
    except Exception as exc:
        append_log(config["runtime_log_path"], f"startup prune skipped: {exc}")
    handler = type("AppHandler", (Handler,), {})
    handler.app = app
    server = ThreadingHTTPServer((config["listen_host"], int(config["listen_port"])), handler)

    tls_cfg = config.get("tls") or {}
    if bool(tls_cfg.get("enabled", True)):
        cert_path = tls_cfg.get("cert_path") or ""
        key_path = tls_cfg.get("key_path") or ""
        if not cert_path or not key_path:
            raise RuntimeError("В config.json не заданы tls.cert_path и tls.key_path")
        if not Path(cert_path).exists() or not Path(key_path).exists():
            raise RuntimeError(f"TLS-файлы не найдены: cert={cert_path} key={key_path}")
        context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        context.load_cert_chain(certfile=cert_path, keyfile=key_path)
        server.socket = context.wrap_socket(server.socket, server_side=True)
        append_log(config["runtime_log_path"], f"UI listening on https://{config['listen_host']}:{config['listen_port']}")
    else:
        append_log(config["runtime_log_path"], f"UI listening on http://{config['listen_host']}:{config['listen_port']}")

    server.serve_forever()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("command", choices=["serve", "rotate"])
    parser.add_argument("--config", required=True)
    args = parser.parse_args()
    config = load_config(args.config)
    if args.command == "serve":
        serve(args.config)
        return
    if not config["rotation"]["enabled"]:
        append_log(config["rotation_log_path"], "rotation skipped because disabled")
        return
    rotate_now(config)


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:
        print(str(exc), file=sys.stderr)
        raise