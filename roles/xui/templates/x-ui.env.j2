# Managed by Ansible — role xui. Не редактировать вручную.
# Файл загружается через systemd EnvironmentFile=/etc/default/x-ui (см. main.go loadServiceEnvFile).
# В v3.4.1+ параметры БД настраиваются только через env, CLI-флаги -dbType/-dbHost и т.д. убраны.

# Бэкенд БД: sqlite (по умолчанию) или postgres
XUI_DB_TYPE={{ xui_db_type }}

# Строка подключения PostgreSQL (используется только при XUI_DB_TYPE=postgres)
XUI_DB_DSN=host={{ xui_db_host }} port={{ xui_db_port }} user={{ xui_db_user }} password={{ xui_db_password }} dbname={{ xui_db_name }} sslmode=disable
